<% title = 'User Dashboard'; css = ['/css/base.css', '/css/style.css']; %>
<%- include('partials/head') %>

<body>
  <%- include('partials/navbar') %>

  <div class="container mt-5">
    <h2 class="brand-text mb-4">👤 User Dashboard</h2>

      <div class="row">
        <div class="col-md-6">
          <div
            class="dashboard-card p-4 rounded text-white"
            style="background: linear-gradient(135deg, #3b82f6, #2563eb)"
          >
            <h5>Total Orders</h5>
            <h2><%= stats.total_orders %></h2>
          </div>
        </div>

        <div class="col-md-6">
          <div
            class="dashboard-card p-4 rounded text-white"
            style="background: linear-gradient(135deg, #22c55e, #15803d)"
          >
            <h5>Total Spending</h5>
            <h2>৳ <%= stats.total_spending %></h2>
          </div>
        </div>
      </div>
    </div>
<%- include('partials/footer') %>
  </body>
</html>
